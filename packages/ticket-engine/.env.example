# --- Notion ---
# ONE internal integration token. Share EVERY project's database with this
# integration. (Works across databases in the same workspace.)
NOTION_TOKEN=secret_xxx

# --- Webhook auth (single shared endpoint) ---
# Long random string. Notion automations send it as X-Webhook-Token.
WEBHOOK_TOKEN=change-me-to-a-long-random-string
# Optional: for Notion API webhook subscriptions, the HMAC verification token.
NOTION_WEBHOOK_SECRET=

# --- Server ---
PORT=8787
# Reserved ngrok domain for `npm run tunnel`, e.g. notion-bot.ngrok.app
NGROK_DOMAIN=

# --- Headless agent ---
# Which agent CLI to drive by default: claude | codex | gemini | aider | cursor.
# Per-project override via "agent" in projects.json. Run `npm run doctor` to see
# which CLIs are installed + authenticated on this machine.
DEFAULT_AGENT=claude
# Default per-ticket wall-clock timeout (minutes). Override per project in projects.json.
AGENT_TIMEOUT_MIN=20

# --- Polling (default mode) ---
# How often the daemon polls every database for trigger-status tickets.
POLL_INTERVAL_SEC=30

# The webhook vars below (WEBHOOK_TOKEN / NGROK_DOMAIN) are only needed for the
# optional `npm run serve` webhook mode — not for the default `npm start` poller.

# Path to the projects config. Defaults to ./projects.json
PROJECTS_FILE=
